{
  "schemaVersion": 1,
  "id": "assistant_interactions_v1",
  "title": "Assistant Interaction Baseline",
  "description": "End-to-end Roca assistant interaction scenarios with mocked agents, projects, approvals, speech, diagnostics, and transcript assertions.",
  "scenarios": [
    {
      "id": "codex_endpoint_lookup_clean_handoff",
      "title": "Codex endpoint lookup",
      "description": "Codex handoff should feel conversational, hide raw tool progress, speak only short summaries, and put endpoint details in Markdown.",
      "tags": ["agent", "codex", "handoff", "speech", "details", "issue-29"],
      "projects": [
        {
          "id": "uni-auth",
          "displayName": "Uni Auth",
          "aliases": ["uni-auth"],
          "localPath": "/workspace/uni-auth"
        }
      ],
      "agent": {
        "providerID": "codex-agent",
        "displayName": "Codex",
        "kind": "noisy",
        "responseText": "| Method | Endpoint |\n|---|---|\n| POST | /v1/auth/passkey/login/begin |\n| POST | /v1/auth/passkey/login/finish |"
      },
      "turns": [
        {
          "id": "ask_endpoints",
          "user": "Can you ask uni-auth in Codex what endpoints there are for passkeys?",
          "outputMode": "speakAll",
          "brain": {
            "directiveJSON": "{\"type\":\"runAgent\",\"providerID\":\"codex-agent\",\"providerName\":\"Codex\",\"projectName\":\"uni-auth\",\"prompt\":\"what passkey endpoints exist?\",\"mode\":\"ask\"}",
            "responseText": "{\"bubbleText\":\"Codex found 2 passkey endpoints. I put the list below.\",\"detailsMarkdown\":\"## Passkey endpoints\\n- POST /v1/auth/passkey/login/begin\\n- POST /v1/auth/passkey/login/finish\"}"
          },
          "expectations": {
            "messages": [
              {
                "role": "assistant",
                "text": "I'll ask Codex to inspect Uni Auth and summarize what it finds."
              },
              {
                "role": "action",
                "text": "Codex finished.",
                "status": "completed"
              },
              {
                "role": "assistant",
                "text": "Codex found 2 passkey endpoints. I put the list below.",
                "detailsContains": "/v1/auth/passkey/login/begin"
              }
            ],
            "forbiddenMessageTextContains": ["listing project files", "grep found passkey routes", "I'll run ls"],
            "spokenTexts": [
              "I'll ask Codex to inspect Uni Auth and summarize what it finds.",
              "Codex found 2 passkey endpoints. I put the list below."
            ],
            "agentRequests": [
              {
                "providerID": "codex-agent",
                "workspacePath": "/workspace/uni-auth",
                "promptContains": "passkey endpoints",
                "mode": "ask"
              }
            ],
            "diagnostics": [
              {
                "kind": "agentRunCompleted",
                "outcome": "completed"
              }
            ]
          }
        }
      ]
    },
    {
      "id": "codex_act_intro_copy",
      "title": "Codex act intro copy",
      "description": "Edit requests should say Roca is asking Codex to make a change, not inspect the project.",
      "tags": ["agent", "codex", "handoff", "copy", "issue-29"],
      "projects": [
        {
          "id": "uni-auth",
          "displayName": "Uni Auth",
          "aliases": ["uni-auth"],
          "localPath": "/workspace/uni-auth"
        }
      ],
      "agent": {
        "providerID": "codex-agent",
        "displayName": "Codex",
        "kind": "normal",
        "responseText": "Updated routes/passkeys.ts."
      },
      "turns": [
        {
          "id": "ask_codex_to_edit",
          "user": "Ask Codex to add a short comment to the Uni Auth passkey route.",
          "outputMode": "speakAll",
          "brain": {
            "directiveJSON": "{\"type\":\"runAgent\",\"providerID\":\"codex-agent\",\"providerName\":\"Codex\",\"projectName\":\"uni-auth\",\"prompt\":\"add a short comment to the passkey route\",\"mode\":\"act\"}",
            "responseText": "{\"bubbleText\":\"Codex updated the passkey route comment.\",\"detailsMarkdown\":\"Changed routes/passkeys.ts.\"}"
          },
          "expectations": {
            "messages": [
              {
                "role": "assistant",
                "text": "I'll ask Codex to make that change in Uni Auth and summarize what changed."
              },
              {
                "role": "assistant",
                "text": "Codex updated the passkey route comment. Changed file: routes/passkeys.ts.",
                "detailsContains": "routes/passkeys.ts"
              }
            ],
            "forbiddenMessageTextContains": ["inspect Uni Auth and summarize what it finds"],
            "spokenTexts": [
              "I'll ask Codex to make that change in Uni Auth and summarize what changed.",
              "Codex updated the passkey route comment. Changed file: routes/passkeys.ts."
            ],
            "agentRequests": [
              {
                "providerID": "codex-agent",
                "workspacePath": "/workspace/uni-auth",
                "promptContains": "short comment",
                "mode": "act"
              }
            ]
          }
        }
      ]
    },
    {
      "id": "read_previous_agent_result_out_loud",
      "title": "Read previous agent result out loud",
      "description": "Follow-up requests to say the previous Codex result should use chat memory, not selected-text reading.",
      "tags": ["agent", "codex", "speech", "memory", "issue-29"],
      "projects": [
        {
          "id": "uni-auth",
          "displayName": "Uni Auth",
          "aliases": ["uni-auth"],
          "localPath": "/workspace/uni-auth"
        }
      ],
      "agent": {
        "providerID": "codex-agent",
        "displayName": "Codex",
        "kind": "normal",
        "responseText": "POST /v1/auth/passkey/login/begin\nPOST /v1/auth/passkey/login/finish"
      },
      "turns": [
        {
          "id": "ask_endpoints",
          "user": "Ask Codex for the Uni Auth passkey endpoints.",
          "brain": {
            "directiveJSON": "{\"type\":\"runAgent\",\"providerID\":\"codex-agent\",\"providerName\":\"Codex\",\"projectName\":\"uni-auth\",\"prompt\":\"list passkey endpoints\",\"mode\":\"ask\"}",
            "responseText": "{\"bubbleText\":\"Codex found 2 passkey endpoints.\",\"detailsMarkdown\":\"## Endpoints\\n- POST /v1/auth/passkey/login/begin\\n- POST /v1/auth/passkey/login/finish\"}"
          },
          "expectations": {
            "messages": [
              {
                "role": "assistant",
                "detailsContains": "/v1/auth/passkey/login/begin"
              }
            ]
          }
        },
        {
          "id": "tell_it_out_loud",
          "user": "Can you tell it to me out loud?",
          "outputMode": "speakAll",
          "brain": {
            "directiveJSON": "{\"type\":\"readSelection\"}",
            "responseText": "{\"bubbleText\":\"Codex found two Uni Auth passkey endpoints: one to begin login and one to finish login.\",\"detailsMarkdown\":null}"
          },
          "expectations": {
            "messages": [
              {
                "role": "assistant",
                "textContains": "begin login"
              }
            ],
            "forbiddenMessageTextContains": ["No selected text found"],
            "spokenTexts": ["Codex found two Uni Auth passkey endpoints: one to begin login and one to finish login."],
            "memoryContains": ["/v1/auth/passkey/login/begin"]
          }
        }
      ]
    },
    {
      "id": "verbal_endpoint_flow_no_markdown",
      "title": "Verbal endpoint flow",
      "description": "When the user asks for a spoken flow, Roca should explain it conversationally instead of printing a Markdown artifact.",
      "tags": ["conversation", "speech", "formatting", "issue-29"],
      "turns": [
        {
          "id": "explain_flow",
          "user": "Can you tell me the flow for the endpoints, not just print them out?",
          "outputMode": "speakAll",
          "brain": {
            "directiveJSON": "{\"type\":\"readSelection\"}",
            "responseText": "{\"bubbleText\":\"Sure. The flow is: start the passkey login, let the client complete the platform challenge, then finish the login with the signed result.\",\"detailsMarkdown\":null}"
          },
          "expectations": {
            "messages": [
              {
                "role": "assistant",
                "textContains": "start the passkey login"
              }
            ],
            "forbiddenMessageTextContains": ["##", "| Method |", "- POST"],
            "spokenTexts": ["Sure. The flow is: start the passkey login, let the client complete the platform challenge, then finish the login with the signed result."]
          }
        }
      ]
    },
    {
      "id": "codex_edit_approval_card",
      "title": "Codex edit approval card",
      "description": "Approval prompts should render as actionable chat cards with approve-once/session/deny outcomes.",
      "tags": ["agent", "codex", "approval"],
      "turns": [
        {
          "id": "approve_edit",
          "user": "Codex wants approval to edit Uni Auth.",
          "approvalPrompt": {
            "title": "Codex needs approval",
            "providerID": "codex-agent",
            "mode": "act",
            "workspacePath": "/workspace/uni-auth",
            "dataScopes": ["prompt", "workspaceFiles"],
            "actionScopes": ["readWorkspace", "runCommands", "editWorkspace"],
            "decision": "approveForSession"
          },
          "expectations": {
            "messages": [
              {
                "role": "action",
                "approvalTitleContains": "Codex needs approval",
                "approvalDecision": "approveForSession",
                "status": "completed"
              },
              {
                "role": "action",
                "text": "Remembered approval."
              }
            ]
          }
        }
      ]
    },
